# Copy to /etc/sipfax/sipfax.env and edit before starting sipfax.service.
# Keep this file readable only by root and the sipfax group.

SIPFAX_HOST=0.0.0.0
SIPFAX_PUBLIC_HOST=replace-me-sipfax-vm-ip
SIPFAX_SIP_PORT=5060
# RTP ports are allocated from this range, one (even) port per concurrent call.
# Size it >= the concurrency cap and open it on the firewall (UDP).
SIPFAX_RTP_PORT_RANGE=40000-40100

# Maximum concurrent modem lines (the FreePBX trunk Max Channels should match).
# Each line is ~1% CPU; size by your VM. Changeable live from the admin UI.
SIPFAX_MAX_SESSIONS=4

# Runtime config file edited by the admin UI. Once it exists it is the source of
# truth; the SIPFAX_* vars here only SEED it on first start.
# SIPFAX_CONFIG_FILE=/etc/sipfax/config.json

SIPFAX_OPERATOR_HOST=127.0.0.1
SIPFAX_OPERATOR_PORT=8080

# Web admin UI (users, cap, live lines, trunk config) at http://<host>:8080/admin.
# It is gated by HTTP Basic auth and DISABLED until a password is set here (or via
# the config file). Set SIPFAX_OPERATOR_HOST=0.0.0.0 to reach it on the LAN, and
# put HTTPS in front (reverse proxy) or keep it on a trusted LAN — Basic auth
# sends credentials on every request.
SIPFAX_ADMIN_USER=admin
# SIPFAX_ADMIN_PASSWORD=replace-me-strong-admin-password

# LKMA-179 reserved FreePBX route.
SIPFAX_FREEPBX_EXTENSION=12345678

# Modem engine: 'spandsp' (default; V.21/V.22bis) or 'slmodem' (V.32bis/V.34 up
# to 33.6k via the free slmodem datapump; requires the 32-bit slmodemd build).
SIPFAX_MODEM_ENGINE=spandsp
# For SIPFAX_MODEM_ENGINE=slmodem:
# SIPFAX_MODEM_MODULATION=v34   # v22bis | v32bis | v34
# SIPFAX_SLMODEMD=/usr/local/bin/slmodemd
# SIPfax defaults to the spandsp soft-modem worker. The service fails fast when
# the binary is unavailable rather than emitting synthetic answer tones.
# SIPFAX_SOFTMODEM_BINARY=/opt/sipfax/bin/sipfax-softmodem
# Optional override for a different external modem adapter. When set, this takes
# precedence over SIPFAX_SOFTMODEM_BINARY.
# SIPFAX_MODEM_COMMAND=/usr/local/bin/sipfax-modem-bridge
# Optional comma-separated arguments for the selected modem command, for example:
# SIPFAX_MODEM_ARGS=--device,/dev/ttyACM0,--baud,115200
# Softmodem start mode. Keep the default v8 for normal Windows calls. Set
# v22bis only during a controlled live fallback test after /healthz reports
# v8Status=failed/v8-failed-v21-fallback.
# SIPFAX_MODEM_START_MODE=v8

# Comma-separated username:password entries (seed only; manage users live in the
# admin UI). SIPfax renders ALL configured users to a 0600 /etc/ppp/{chap,pap}-
# secrets file so concurrent calls can each authenticate. For example:
# SIPFAX_PPP_USERS=modem-user:replace-with-generated-secret
SIPFAX_PPP_USERS=replace-me-user:replace-me-password
SIPFAX_PPP_POOL=10.64.0.0/24
# Optional; defaults to first host in SIPFAX_PPP_POOL.
# SIPFAX_PPP_LOCAL_ADDRESS=10.64.0.1
SIPFAX_PPP_DNS=1.1.1.1,9.9.9.9
# Requires the Debian ppp package. SIPfax starts pppd when the soft-modem
# worker reports a pty-opened control event.
SIPFAX_PPPD_COMMAND=/usr/sbin/pppd
# CHAP is the default; set to pap only for clients that cannot speak CHAP.
SIPFAX_PPP_AUTH=chap
# Optional script used for pppd ip-up/ip-down notifications. It should emit
# JSON lines with state IPCP-open/IPCP-close plus interfaceName when configured.
# SIPFAX_PPP_NOTIFY_SCRIPT=/usr/lib/sipfax/ppp-notify
# SIPfax writes per-call egress descriptors here. The root-owned pppd hooks read
# these descriptors and apply nftables/iptables forwarding outside the service.
SIPFAX_PPP_LEASE_DIR=/run/sipfax/ppp-leases

# Set to the VM interface used for outbound traffic, for example ens18.
SIPFAX_EGRESS_INTERFACE=replace-me-uplink-interface
SIPFAX_EGRESS_ENABLED=true
SIPFAX_EGRESS_DNS=true
SIPFAX_EGRESS_ALLOW=0.0.0.0/0
# Loopback diagnostics endpoint used by the privileged egress helper.
# SIPFAX_OPERATOR_URL=http://127.0.0.1:8080
